{
  "name": "vorasec-webpage",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/_worker.js/index.js",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "vorasec.com",
      "custom_domain": true
    }
  ],

  "keep_vars": true,

  "send_email": [
    {
      "name": "CONTACT_EMAIL",
      "destination_address": "info@vorasec.com"
    }
  ],

  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },

  "r2_buckets": [
    {
      "binding": "BRIEFINGS_BUCKET",
      "bucket_name": "n8n-cybernews"
    }
  ],

  "observability": {
    "enabled": true
  },

  "upload_source_maps": true
}
