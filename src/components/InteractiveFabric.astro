<div class="fabric" aria-hidden="true">
	<canvas data-interactive-fabric></canvas>
</div>

<script>
	const canvases = document.querySelectorAll<HTMLCanvasElement>('[data-interactive-fabric]');

	for (const canvas of canvases) {
		if (canvas.dataset.ready) continue;
		canvas.dataset.ready = 'true';

		const context = canvas.getContext('2d');
		const host = canvas.closest<HTMLElement>('[data-fabric-host]');
		const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
		const finePointer = window.matchMedia('(pointer: fine)');

		if (!context || !host) continue;

		let width = 0;
		let height = 0;
		let frame = 0;
		let visible = true;
		let active = false;
		let lastTime = performance.now();

		const pointer = { x: 0, y: 0.54, depth: 0.5, strength: 0 };
		const target = { x: 0, y: 0.54, depth: 0.5, strength: 0 };

		const resize = () => {
			const rect = host.getBoundingClientRect();
			width = Math.max(1, rect.width);
			height = Math.max(1, rect.height);
			const pixelRatio = Math.min(window.devicePixelRatio || 1, 1.75);

			canvas.width = Math.round(width * pixelRatio);
			canvas.height = Math.round(height * pixelRatio);
			canvas.style.width = `${width}px`;
			canvas.style.height = `${height}px`;
			context.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0);
			draw(performance.now());
		};

		const point = (column: number, row: number, columns: number, rows: number, time: number) => {
			const x = (column / columns) * 2 - 1;
			const depth = row / rows;
			const easedDepth = Math.pow(depth, 1.55);
			const horizon = height * (0.435 + pointer.y * 0.025);
			const spread = width * (0.09 + easedDepth * 0.64);
			const center = width * 0.64 + pointer.x * width * 0.035 * (1 - easedDepth);
			const wave =
				Math.sin(x * 4.6 + depth * 3.2 + time * 0.00042) * 9 +
				Math.sin(x * 2.1 - depth * 5.4 - time * 0.00026) * 5;
			const distanceX = x - pointer.x * 0.78;
			const distanceZ = depth - pointer.depth;
			const lift =
				Math.exp(-(distanceX * distanceX * 5.5 + distanceZ * distanceZ * 16)) *
				pointer.strength *
				42;
			const tilt = x * pointer.x * 22 * easedDepth;

			return {
				x: center + x * spread,
				y:
					horizon +
					easedDepth * (height - horizon) * 1.08 +
					wave * (0.2 + easedDepth * 0.86) +
					tilt -
					lift,
				depth,
			};
		};

		const draw = (time: number) => {
			if (!width || !height) return;

			context.clearRect(0, 0, width, height);
			const columns = width < 700 ? 22 : 34;
			const rows = width < 700 ? 17 : 23;
			const points = Array.from({ length: rows + 1 }, (_, row) =>
				Array.from({ length: columns + 1 }, (_, column) => point(column, row, columns, rows, time)),
			);

			const lineGradient = context.createLinearGradient(width * 0.18, height * 0.42, width, height);
			lineGradient.addColorStop(0, 'rgba(115, 214, 232, 0)');
			lineGradient.addColorStop(0.42, 'rgba(115, 214, 232, 0.13)');
			lineGradient.addColorStop(1, 'rgba(167, 240, 207, 0.2)');
			context.strokeStyle = lineGradient;
			context.lineWidth = 0.7;

			for (let column = 0; column <= columns; column += 1) {
				context.beginPath();
				for (let row = 0; row <= rows; row += 1) {
					const current = points[row][column];
					if (row === 0) context.moveTo(current.x, current.y);
					else context.lineTo(current.x, current.y);
				}
				context.stroke();
			}

			for (let row = 1; row <= rows; row += 1) {
				context.globalAlpha = 0.28 + (row / rows) * 0.72;
				context.beginPath();
				for (let column = 0; column <= columns; column += 1) {
					const current = points[row][column];
					if (column === 0) context.moveTo(current.x, current.y);
					else context.lineTo(current.x, current.y);
				}
				context.stroke();
			}

			context.globalAlpha = 1;
			for (let row = 2; row <= rows; row += 2) {
				for (let column = 0; column <= columns; column += 2) {
					if ((column * 17 + row * 13) % 7 > 1) continue;
					const current = points[row][column];
					const pulse = 0.64 + Math.sin(time * 0.0015 + column * 0.7 + row) * 0.28;
					context.fillStyle = `rgba(115, 224, 242, ${Math.max(0.18, pulse)})`;
					context.beginPath();
					context.arc(current.x, current.y, 0.65 + current.depth * 0.75, 0, Math.PI * 2);
					context.fill();
				}
			}

			if (pointer.strength > 0.02) {
				const column = Math.round(((pointer.x * 0.78 + 1) / 2) * columns);
				const row = Math.round(pointer.depth * rows);
				const focus = points[Math.max(0, Math.min(rows, row))][Math.max(0, Math.min(columns, column))];
				const glow = context.createRadialGradient(focus.x, focus.y, 0, focus.x, focus.y, 82);
				glow.addColorStop(0, `rgba(115, 214, 232, ${0.1 * pointer.strength})`);
				glow.addColorStop(1, 'rgba(115, 214, 232, 0)');
				context.fillStyle = glow;
				context.fillRect(focus.x - 82, focus.y - 82, 164, 164);
			}
		};

		const tick = (time: number) => {
			frame = 0;
			const smoothing = 1 - Math.pow(0.0008, Math.min(0.05, (time - lastTime) / 1000));
			lastTime = time;
			pointer.x += (target.x - pointer.x) * smoothing;
			pointer.y += (target.y - pointer.y) * smoothing;
			pointer.depth += (target.depth - pointer.depth) * smoothing;
			pointer.strength += (target.strength - pointer.strength) * smoothing;
			draw(time);

			if (active && visible && !document.hidden && !reducedMotion.matches) {
				frame = requestAnimationFrame(tick);
			}
		};

		const start = () => {
			active = true;
			if (!frame && visible && !document.hidden && !reducedMotion.matches) {
				lastTime = performance.now();
				frame = requestAnimationFrame(tick);
			} else if (reducedMotion.matches) {
				draw(0);
			}
		};

		const stop = () => {
			active = false;
			if (frame) cancelAnimationFrame(frame);
			frame = 0;
		};

		const updatePointer = (event: PointerEvent) => {
			if (!finePointer.matches) return;
			const rect = host.getBoundingClientRect();
			const relativeX = Math.max(0, Math.min(1, (event.clientX - rect.left) / rect.width));
			const relativeY = Math.max(0, Math.min(1, (event.clientY - rect.top) / rect.height));
			const horizon = 0.45;
			const projectedDepth = Math.max(0, Math.min(1, (relativeY - horizon) / (1 - horizon)));

			target.x = relativeX * 2 - 1;
			target.y = relativeY;
			target.depth = Math.pow(projectedDepth, 1 / 1.55);
			target.strength = 1;
		};

		const releasePointer = () => {
			target.x = 0;
			target.y = 0.54;
			target.depth = 0.5;
			target.strength = 0;
		};

		const observer = new IntersectionObserver(
			([entry]) => {
				visible = entry.isIntersecting;
				if (visible) start();
				else stop();
			},
			{ threshold: 0.02 },
		);

		const resizeObserver = new ResizeObserver(resize);
		resizeObserver.observe(host);
		observer.observe(host);
		host.addEventListener('pointermove', updatePointer, { passive: true });
		host.addEventListener('pointerleave', releasePointer, { passive: true });
		document.addEventListener('visibilitychange', () => {
			if (document.hidden) stop();
			else if (visible) start();
		});
		reducedMotion.addEventListener('change', () => {
			if (reducedMotion.matches) {
				stop();
				draw(0);
			} else if (visible) {
				start();
			}
		});
		start();
	}
</script>

<style>
	.fabric {
		position: absolute;
		z-index: 0;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
		opacity: 0.78;
		-webkit-mask-image: radial-gradient(ellipse 88% 76% at 72% 82%, #000 7%, rgba(0, 0, 0, 0.86) 56%, transparent 94%);
		mask-image: radial-gradient(ellipse 88% 76% at 72% 82%, #000 7%, rgba(0, 0, 0, 0.86) 56%, transparent 94%);
	}

	.fabric::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, rgba(32, 36, 43, 0.78) 0%, transparent 55%);
	}

	canvas {
		display: block;
		width: 100%;
		height: 100%;
	}

	@media (max-width: 760px) {
		.fabric {
			opacity: 0.68;
			-webkit-mask-image: radial-gradient(ellipse 125% 68% at 64% 88%, #000 9%, rgba(0, 0, 0, 0.82) 54%, transparent 96%);
			mask-image: radial-gradient(ellipse 125% 68% at 64% 88%, #000 9%, rgba(0, 0, 0, 0.82) 54%, transparent 96%);
		}
	}
</style>
