---
const { title, description = 'Cybersecurity, technology, and AI-powered security briefings.' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  ['/', 'Home'],
  ['/about', 'About'],
  ['/blog', 'Blog'],
  ['/podcast', 'AI Podcast'],
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#20242b" />
  <link rel="icon" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <a class="skip" href="#main">Skip to content</a>
  <header>
    <div class="shell bar">
      <a class="brand" href="/">vorasec<span>.</span></a>
      <nav aria-label="Primary navigation"><ul>{nav.map(([href,label]) => <li><a class:list={{active: href === '/' ? path === '/' : path.startsWith(href)}} href={href}>{label}</a></li>)}</ul></nav>
    </div>
  </header>
  <main id="main"><slot /></main>
  <footer><div class="shell foot"><p>© {new Date().getFullYear()} David.</p><p><a href="/blog">Writing</a> · <a href="/podcast">Podcast</a></p></div></footer>
</body>
</html>
<style is:global>
:root{color-scheme:dark;--bg:#20242b;--bg2:#272c34;--text:#e5e7eb;--muted:#aeb4be;--line:rgba(255,255,255,.08);--a:#73d6e8;--b:#a7f0cf;--max:1080px}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:linear-gradient(135deg,#1f2329 0%,#262b32 48%,#20242b 100%);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;line-height:1.65}.shell{width:min(calc(100% - 2.5rem),var(--max));margin:auto}a{color:inherit}.skip{position:absolute;top:-5rem}.skip:focus{top:1rem}header{position:sticky;top:0;z-index:10;background:rgba(32,36,43,.82);backdrop-filter:blur(18px)}.bar{min-height:72px;display:flex;align-items:center;justify-content:space-between;gap:1rem}.brand{text-decoration:none;font-weight:800;letter-spacing:-.03em}.brand span{color:var(--a)}nav ul{display:flex;gap:1.5rem;list-style:none;margin:0;padding:0}nav a{display:block;text-decoration:none;color:var(--muted);font-size:.95rem}nav a:hover,nav a.active{color:var(--text)}h1,h2,h3{line-height:1.08;letter-spacing:-.045em;font-weight:650}h1{font-size:clamp(3.2rem,8vw,6.8rem);margin:.25rem 0 1.4rem;max-width:980px}h2{font-size:clamp(2rem,4vw,3.6rem);margin:.2rem 0 1.2rem}h3{font-size:1.35rem;margin:.2rem 0 .5rem}p{color:var(--muted)}.eyebrow{color:var(--b);text-transform:uppercase;letter-spacing:.16em;font-weight:700;font-size:.74rem}.hero{padding:9rem 0 7rem}.hero>p:not(.eyebrow){max-width:720px;font-size:1.2rem}.section{padding:5rem 0}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3rem}.card{padding:0;background:none;border:0;box-shadow:none}.tags{display:flex;flex-wrap:wrap;gap:.7rem 1rem;list-style:none;padding:0}.tags li{padding:0;color:var(--muted)}.buttons{display:flex;flex-wrap:wrap;gap:1.2rem;margin-top:2rem}.button{display:inline-flex;padding:.72rem 0;text-decoration:none;font-weight:700;border:0;border-bottom:1px solid rgba(255,255,255,.24);border-radius:0}.button:hover{border-color:var(--text)}.primary{background:linear-gradient(90deg,var(--a),var(--b));-webkit-background-clip:text;background-clip:text;color:transparent;border-color:var(--a)}.prose{width:min(calc(100% - 2.5rem),760px);margin:auto;padding:7rem 0}.prose h1{font-size:clamp(2.8rem,7vw,5rem)}.prose h2{margin-top:3rem}.prose p,.prose li{color:#c7cbd1}.prose a{color:var(--a)}footer{margin-top:5rem}.foot{min-height:120px;display:flex;justify-content:space-between;align-items:center;gap:1rem;border-top:1px solid var(--line)}.foot p{font-size:.9rem}@media(max-width:760px){.bar{align-items:flex-start;flex-direction:column;padding:1rem 0}nav{width:100%;overflow:auto}nav ul{width:max-content}.grid{grid-template-columns:1fr;gap:2.5rem}.hero{padding-top:5rem}.foot{align-items:flex-start;flex-direction:column;padding:2rem 0}}
</style>
