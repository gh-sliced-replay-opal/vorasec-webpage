---
import BrandMark from '../components/BrandMark.astro';

const { title, description = 'Practical personal and home cybersecurity for individuals and families.' } = Astro.props;
const path = Astro.url.pathname;
const normalizedPath = path.replace(/\/+$/, '') || '/';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#20242b" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="preload" href="/fonts/instrument-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/antonio-latin.woff2" as="font" type="font/woff2" crossorigin />
  <title>{title}</title>
</head>
<body>
  <a class="skip" href="#main">Skip to content</a>
  <header>
    <div class="shell bar">
      <BrandMark />
      <nav aria-label="Primary navigation">
        <ul>
          <li><a class:list={{ active: normalizedPath === '/' }} href="/">Home</a></li>
          <li class="nav-menu">
            <details>
              <summary class:list={{ active: normalizedPath.startsWith('/services') }}>
                Services <span aria-hidden="true">⌄</span>
              </summary>
              <div class="nav-menu-panel">
                <a class:list={{ active: normalizedPath === '/services' }} href="/services">All services</a>
                <a class:list={{ active: normalizedPath === '/services/personal-protection' }} href="/services/personal-protection">Personal protection</a>
                <a class:list={{ active: normalizedPath === '/services/home-network-protection' }} href="/services/home-network-protection">Home network protection</a>
              </div>
            </details>
          </li>
          <li><a class:list={{ active: normalizedPath === '/about' }} href="/about">About</a></li>
          <li><a class:list={{ active: normalizedPath === '/podcast' }} href="/podcast">AI Podcast</a></li>
        </ul>
      </nav>
    </div>
  </header>
  <main id="main"><slot /></main>
  <footer><div class="shell foot"><p>© {new Date().getFullYear()} VoraSec LLC</p><p><a href="/services">Services</a> · <a href="/about">About</a> · <a href="/podcast">Podcast</a> · <a href="/services#contact">Contact</a></p></div></footer>
</body>
</html>
<style is:global>
:root{color-scheme:dark;--bg:#20242b;--bg2:#272c34;--text:#e5e7eb;--muted:#aeb4be;--line:rgba(255,255,255,.08);--a:#73d6e8;--b:#a7f0cf;--max:1080px}
@font-face{font-family:"Instrument Sans";src:url("/fonts/instrument-sans-latin.woff2") format("woff2");font-style:normal;font-weight:400 700;font-display:swap}
@font-face{font-family:"Antonio";src:url("/fonts/antonio-latin.woff2") format("woff2");font-style:normal;font-weight:500 700;font-display:swap}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:linear-gradient(135deg,#1f2329 0%,#262b32 48%,#20242b 100%);color:var(--text);font-family:"Instrument Sans",ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;line-height:1.65}.shell{width:min(calc(100% - 2.5rem),var(--max));margin:auto}a{color:inherit}.skip{position:absolute;top:-5rem}.skip:focus{top:1rem}header{position:sticky;top:0;z-index:10;background:rgba(32,36,43,.82);backdrop-filter:blur(18px)}.bar{min-height:72px;display:flex;align-items:center;justify-content:space-between;gap:1rem}nav ul{display:flex;align-items:center;gap:1.5rem;list-style:none;margin:0;padding:0}nav a,nav summary{display:flex;align-items:center;gap:.3rem;text-decoration:none;color:var(--muted);font-size:.95rem}nav summary{cursor:pointer;list-style:none}nav summary::-webkit-details-marker{display:none}nav a:hover,nav a.active,nav summary:hover,nav summary.active{color:var(--text)}.nav-menu{position:relative}.nav-menu-panel{position:absolute;top:calc(100% + .65rem);left:-1rem;display:grid;min-width:245px;padding:.55rem;border:1px solid var(--line);background:rgba(32,36,43,.98);box-shadow:0 18px 48px rgba(0,0,0,.28)}.nav-menu-panel a{padding:.55rem .7rem;white-space:nowrap}.nav-menu-panel a:hover{background:rgba(255,255,255,.04)}h1,h2,h3{font-family:"Antonio",sans-serif;line-height:1.05;letter-spacing:-.012em;font-weight:600}h1{font-size:clamp(2.7rem,5.2vw,4.55rem);margin:.25rem 0 1.4rem;max-width:840px}h2{font-size:clamp(1.75rem,2.9vw,2.55rem);margin:.2rem 0 1.2rem}h3{font-size:1.1rem;margin:.2rem 0 .5rem;line-height:1.08}p{color:var(--muted)}.eyebrow{color:var(--b);text-transform:uppercase;letter-spacing:.16em;font-weight:700;font-size:.74rem}.hero{padding:9rem 0 7rem}.hero>p:not(.eyebrow){max-width:720px;font-size:1.2rem}.section{padding:5rem 0}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3rem}.card{padding:0;background:none;border:0;box-shadow:none}.tags{display:flex;flex-wrap:wrap;gap:.7rem 1rem;list-style:none;padding:0}.tags li{padding:0;color:var(--muted)}.buttons{display:flex;flex-wrap:wrap;gap:1.2rem;margin-top:2rem}.button{display:inline-flex;padding:.72rem 0;text-decoration:none;font-weight:700;border:0;border-bottom:1px solid rgba(255,255,255,.24);border-radius:0}.button:hover{border-color:var(--text)}.primary{background:linear-gradient(90deg,var(--a),var(--b));-webkit-background-clip:text;background-clip:text;color:transparent;border-color:var(--a)}.prose{width:min(calc(100% - 2.5rem),760px);margin:auto;padding:7rem 0}.prose h1{font-size:clamp(2.5rem,4.6vw,3.8rem)}.prose h2{margin-top:3rem}.prose p,.prose li{color:#c7cbd1}.prose a{color:var(--a)}footer{margin-top:5rem}.foot{min-height:120px;display:flex;justify-content:space-between;align-items:center;gap:1rem;border-top:1px solid var(--line)}.foot p{font-size:.9rem}@media(max-width:760px){.bar{align-items:flex-start;flex-direction:column;padding:1rem 0}nav{width:100%;overflow:visible}nav ul{width:100%;gap:1rem}.nav-menu-panel{left:-.75rem}.grid{grid-template-columns:1fr;gap:2.5rem}.hero{padding-top:5rem}.foot{align-items:flex-start;flex-direction:column;padding:2rem 0}}
</style>
