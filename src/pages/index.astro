---
import BaseLayout from '../layouts/BaseLayout.astro';

const concerns = [
  {
    title: 'Accounts & identity',
    text: 'Secure important accounts, strengthen recovery options, reduce unnecessary public exposure, and prepare your household to recognize financial and impersonation scams.',
  },
  {
    title: 'Scams & suspicious messages',
    text: 'Get a trusted second opinion before responding to an email, text, call, website, invoice, or online request that does not feel right.',
  },
  {
    title: 'Home networks',
    text: 'Replace one shared Wi-Fi network with a professionally configured system that separates personal devices, guests, cameras, and connected home technology.',
  },
];

const principles = [
  ['Plain-language guidance', 'We explain what we find, why it matters, and what we recommend without expecting you to speak cybersecurity.'],
  ['Permission at every step', 'We only inspect accounts, information, devices, and networks you have authorized us to review.'],
  ['Protection you own', 'Your accounts, equipment, configurations, and documentation remain yours.'],
  ['Priorities you can act on', 'We separate urgent concerns from sensible improvements so you know what to address first.'],
];
---

<BaseLayout
  title="VoraSec | Personal & Home Cybersecurity"
  description="Practical cybersecurity for individuals and families, including account and identity protection, scam support, exposure reviews, secure home networks, and ongoing care."
>
  <section class="hero brand-hero shell">
    <img
      class="hero-logo"
      src="/vorasec-logo.png"
      alt="VoraSec"
      width="720"
      height="720"
      decoding="async"
      fetchpriority="high"
    />

    <div class="hero-copy">
      <p class="eyebrow">Personal & home cybersecurity</p>
      <h1>Protect the digital life you’ve built.</h1>
      <p>
        We help individuals and families secure the accounts, personal information,
        and home technology they rely on every day. Our services combine clear
        guidance, hands-on protection, and ongoing support—without fear-based
        selling or enterprise jargon.
      </p>
      <div class="buttons">
        <a class="button primary" href="/services">Explore our services</a>
        <a class="button" href="/services#contact">Talk with VoraSec</a>
      </div>
    </div>
  </section>

  <section class="section shell" aria-labelledby="real-life-heading">
    <p class="eyebrow">Security for real life</p>
    <h2 id="real-life-heading">Your risks do not stop at a password.</h2>
    <p class="section-lede">
      A suspicious message, exposed personal information, compromised email account,
      or poorly secured home network can affect far more than one device. We help you
      understand what matters, fix what can be fixed, and build protection that fits
      your household.
    </p>
    <div class="concern-grid">
      {concerns.map((concern) => (
        <article>
          <h3>{concern.title}</h3>
          <p>{concern.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section shell" aria-labelledby="paths-heading">
    <p class="eyebrow">Two ways we protect your household</p>
    <h2 id="paths-heading">Start with the part of your digital life that needs attention.</h2>
    <div class="path-grid">
      <a
        class="path-card"
        href="/services/personal-protection"
        aria-label="Explore Personal Protection services"
      >
        <article>
          <p class="path-label">Personal protection</p>
          <h3>Protect your accounts, identity, and privacy.</h3>
          <p>
            Most families start with Essentials. Account Protection adds hands-on
            help with important accounts, identity, and privacy. Exposure Review adds
            an authorized look at what outsiders can find and reach. Personal
            Protection Care is available after Account Protection or Exposure Review.
          </p>
          <ul>
            <li>Essentials</li>
            <li>Account Protection</li>
            <li>Exposure Review</li>
            <li>Personal Protection Care</li>
          </ul>
          <span class="path-cta" aria-hidden="true">Explore Personal Protection <span>→</span></span>
        </article>
      </a>
      <a
        class="path-card"
        href="/services/home-network-protection"
        aria-label="Explore Home Network Protection services"
      >
        <article>
          <p class="path-label">Home network protection</p>
          <h3>Build a safer foundation for everything connected at home.</h3>
          <p>
            Network Deployment creates a professionally configured UniFi home network
            designed around your household and owned by you. Ongoing Home Security
            Care is available after Network Deployment.
          </p>
          <ul>
            <li>Network Deployment</li>
            <li>Ongoing Home Security Care</li>
          </ul>
          <span class="path-cta" aria-hidden="true">Explore Home Network Protection <span>→</span></span>
        </article>
      </a>
    </div>
  </section>

  <section class="section shell" aria-labelledby="expect-heading">
    <p class="eyebrow">What to expect</p>
    <h2 id="expect-heading">Clear recommendations. Careful work. You remain in control.</h2>
    <div class="principles-grid">
      {principles.map(([title, text]) => (
        <article>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section shell founder" aria-labelledby="founder-heading">
    <div>
      <p class="eyebrow">Experience behind VoraSec</p>
      <h2 id="founder-heading">Built by someone who has handled real security incidents.</h2>
    </div>
    <div>
      <p>
        VoraSec was founded by David, a military veteran and cybersecurity
        professional with experience across government, enterprise security, and
        global managed detection and response. His background includes incident
        response, malware analysis, detection engineering, and cyber threat intelligence.
      </p>
      <p>
        David holds a master’s degree in Cybersecurity and Information Assurance and
        the GIAC Certified Incident Handler credential, among other certifications.
      </p>
      <a class="button" href="/about">Meet the founder and learn about his work</a>
    </div>
  </section>

  <section class="section shell final-cta">
    <p class="eyebrow">Start with what needs protecting</p>
    <h2>Tell us what concerns you. We’ll help identify the right place to begin.</h2>
    <div class="buttons">
      <a class="button primary" href="/services">View all services</a>
      <a class="button" href="/services#contact">Contact VoraSec</a>
    </div>
  </section>
</BaseLayout>

<style>
  .brand-hero {
    --hero-logo-width: clamp(14rem, 27vw, 19rem);
    --hero-heading-gap: 6rem;
    position: relative;
    min-height: min(760px, calc(100vh - 72px));
    overflow: hidden;
    isolation: isolate;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    max-width: none;
  }

  .hero-copy h1 {
    max-width: calc(100% - var(--hero-logo-width) - var(--hero-heading-gap));
  }

  .hero-copy > p:not(.eyebrow) {
    max-width: 720px;
  }

  .hero-logo {
    position: absolute;
    z-index: 1;
    top: 2.4rem;
    right: -1rem;
    width: var(--hero-logo-width);
    height: auto;
    opacity: 0.4;
    mask-image: linear-gradient(135deg, #000 55%, rgba(0, 0, 0, 0.78) 78%, transparent 100%);
  }

  .brand-hero::after {
    content: '';
    position: absolute;
    z-index: -2;
    inset: 0;
    background:
      radial-gradient(circle at 88% 16%, rgba(115, 214, 232, 0.08), transparent 28%),
      linear-gradient(115deg, transparent 45%, rgba(39, 44, 52, 0.2));
    pointer-events: none;
  }

  .section-lede {
    max-width: 760px;
    font-size: 1.08rem;
  }

  .concern-grid,
  .principles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-top: 3rem;
  }

  .concern-grid article,
  .principles-grid article {
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .principles-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .path-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .path-card {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .path-card article {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.018);
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      transform 160ms ease;
  }

  .path-card:hover article,
  .path-card:focus-visible article {
    border-color: var(--a);
    background: rgba(255, 255, 255, 0.035);
    transform: translateY(-2px);
  }

  .path-card:focus-visible {
    outline: 2px solid var(--a);
    outline-offset: 4px;
  }

  .path-card h3 {
    max-width: 420px;
    font-size: clamp(1.55rem, 3vw, 2.15rem);
  }

  .path-grid ul {
    margin: 1.5rem 0;
    padding-left: 1.2rem;
    color: var(--muted);
  }

  .path-grid li {
    margin: 0.5rem 0;
  }

  .path-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    color: var(--text);
    font-weight: 700;
  }

  .path-cta span {
    color: var(--a);
    font-size: 1.25rem;
    transition: transform 160ms ease;
  }

  .path-card:hover .path-cta span,
  .path-card:focus-visible .path-cta span {
    transform: translateX(0.25rem);
  }

  .path-label {
    color: var(--b);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .founder {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 6rem;
  }

  .founder p {
    max-width: 680px;
  }

  .final-cta {
    max-width: 900px;
    margin-left: max(1.25rem, calc((100vw - var(--max)) / 2));
  }

  @media (max-width: 760px) {
    .brand-hero {
      --hero-logo-width: 10rem;
      min-height: 690px;
      padding-top: 13.5rem;
    }

    .hero-copy h1 {
      max-width: 100%;
    }

    .hero-logo {
      top: 1.2rem;
      right: -0.5rem;
      width: var(--hero-logo-width);
      opacity: 0.3;
    }

    .concern-grid,
    .principles-grid,
    .path-grid,
    .founder {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .path-card article {
      padding: 1.5rem;
    }
  }
</style>
