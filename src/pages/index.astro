---
import BaseLayout from '../layouts/BaseLayout.astro';
const areas = [
  ['Cyber Threat Intelligence', 'Adversary tracking, TTP analysis, IOC development, and intelligence reporting that helps defenders act.'],
  ['Detection & Incident Response', 'Detection development, incident triage, malware analysis, containment, and clear threat intelligence reporting for technical teams and stakeholders.'],
  ['Analyst Enablement & Automation', 'Training, repeatable workflows, and responsible automation that help analysts work with more context and confidence.'],
];
const impact = [
  'Helped uncover and disrupt a software supply-chain attack distributing SeroXen malware through a NuGet repository with more than two million downloads.',
  'Trusted to lead threat intelligence analysis and train analysts on adversary tactics, techniques, and procedures.',
  'Developed signatures and intelligence used to identify and track sophisticated threat actor activity.',
];
---
<BaseLayout
  title="David | Cybersecurity, Technology & AI"
  description="David's work in cyber threat intelligence, intrusion analysis, incident response, detection engineering, and security automation."
>
  <section class="hero brand-hero shell">
    <img
      class="hero-logo"
      src="/vorasec-logo.png"
      alt="VORASEC"
      width="720"
      height="720"
      decoding="async"
      fetchpriority="high"
    />

    <div class="hero-copy">
      <p class="eyebrow">Cyber Threat Intelligence · Intrusion Analysis · Incident Response</p>
      <h1>I identify active intrusions, connect adversary behavior across data, and turn raw telemetry into action.</h1>
      <p>
        I’m David, a military veteran and cybersecurity professional with experience
        across government, enterprise security, and global managed detection and
        response. My work spans threat intelligence, threat actor tracking, detection
        development, malware analysis, incident response, and analyst enablement.
      </p>
      <div class="buttons">
        <a class="button primary" href="/about">About my work</a>
        <a class="button" href="/services">Explore VoraSec services</a>
      </div>
    </div>
  </section>

  <section class="section shell">
    <p class="eyebrow">What I work on</p>
    <h2>Security with an operator’s perspective.</h2>
    <div class="grid">
      {areas.map(([title, text]) => (
        <article>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section shell impact">
    <p class="eyebrow">Selected impact</p>
    <h2>Evidence from the work.</h2>
    <div class="impact-grid">
      {impact.map((item) => (
        <article><p>{item}</p></article>
      ))}
    </div>
  </section>

  <section class="section shell project">
    <p class="eyebrow">Current project</p>
    <h2>AI-powered cyber briefings</h2>
    <p>
      An automated pipeline that collects trusted reporting, prioritizes
      exploited vulnerabilities, and delivers a concise audio briefing.
    </p>
    <a class="button" href="/podcast">Explore the project</a>
  </section>
</BaseLayout>

<style>
  .brand-hero {
    --hero-logo-width: clamp(14rem, 27vw, 19rem);
    --hero-heading-gap: 6rem;
    position: relative;
    min-height: min(760px, calc(100vh - 72px));
    overflow: hidden;
    isolation: isolate;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    max-width: none;
  }

  .hero-copy h1 {
    max-width: calc(100% - var(--hero-logo-width) - var(--hero-heading-gap));
  }

  .hero-copy > p:not(.eyebrow) {
    max-width: 720px;
  }

  .hero-logo {
    position: absolute;
    z-index: 1;
    top: 2.4rem;
    right: -1rem;
    width: var(--hero-logo-width);
    height: auto;
    opacity: 0.4;
    mask-image: linear-gradient(135deg, #000 55%, rgba(0, 0, 0, 0.78) 78%, transparent 100%);
  }

  .brand-hero::after {
    content: '';
    position: absolute;
    z-index: -2;
    inset: 0;
    background:
      radial-gradient(circle at 88% 16%, rgba(115, 214, 232, 0.08), transparent 28%),
      linear-gradient(115deg, transparent 45%, rgba(39, 44, 52, 0.2));
    pointer-events: none;
  }

  .project {
    max-width: 760px;
    margin-left: max(1.25rem, calc((100vw - var(--max)) / 2));
  }

  .impact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-top: 3rem;
  }

  .impact-grid article {
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .impact-grid p {
    margin-top: 0;
  }

  @media (max-width: 760px) {
    .brand-hero {
      --hero-logo-width: 10rem;
      min-height: 690px;
      padding-top: 13.5rem;
    }

    .hero-copy h1 {
      max-width: 100%;
    }

    .hero-logo {
      top: 1.2rem;
      right: -0.5rem;
      width: var(--hero-logo-width);
      opacity: 0.3;
    }

    .impact-grid {
      grid-template-columns: 1fr;
    }

  }
</style>
