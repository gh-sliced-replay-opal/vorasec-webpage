---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  EPISODES_PER_PAGE,
  episodeTitle,
  pairEpisodes,
  publicObjectUrl,
  renderShowNotes,
} from '../lib/podcast';

export const prerender = false;

Astro.response.headers.set('Cache-Control', 'no-store');

async function listAllObjects(bucket: R2Bucket): Promise<R2Object[]> {
  const objects: R2Object[] = [];
  let cursor: string | undefined;

  do {
    const result = await bucket.list({
      cursor,
      limit: 1000,
      prefix: 'briefings/',
    });
    objects.push(...result.objects);
    cursor = result.truncated ? result.cursor : undefined;
  } while (cursor);

  return objects;
}

const requestedPage = Number.parseInt(Astro.url.searchParams.get('page') ?? '1', 10);
const currentPage = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : 1;

let loadError = '';
let episodes = [] as Array<ReturnType<typeof pairEpisodes>[number] & { notesHtml?: string }>;
let totalEpisodes = 0;

try {
  const allObjects = await listAllObjects(env.BRIEFINGS_BUCKET);
  const paired = pairEpisodes(allObjects);
  totalEpisodes = paired.length;

  const start = (currentPage - 1) * EPISODES_PER_PAGE;
  const pageItems = paired.slice(start, start + EPISODES_PER_PAGE);

  episodes = await Promise.all(pageItems.map(async (episode) => {
    if (!episode.notesKey) return episode;
    const notesObject = await env.BRIEFINGS_BUCKET.get(episode.notesKey);
    if (!notesObject) return episode;
    return { ...episode, notesHtml: renderShowNotes(await notesObject.text()) };
  }));
} catch (error) {
  console.error('Unable to load podcast episodes from R2', error);
  loadError = 'The episode archive is temporarily unavailable.';
}

const totalPages = Math.max(1, Math.ceil(totalEpisodes / EPISODES_PER_PAGE));
---

<BaseLayout
  title="AI-Powered Podcast | VoraSec"
  description="AI-assisted cybersecurity audio briefings with source-linked show notes."
>
  <section class="hero shell podcast-intro">
    <p class="eyebrow">AI-powered podcast</p>

    <h1>Cybersecurity briefings, ready when you are.</h1>

    <p>
      Current security reporting prioritized around active
      exploitation, high-impact threats, and the technologies I
      follow.
    </p>
  </section>

  <section
    class="episodes shell"
    aria-labelledby="episodes-heading"
  >
    <div class="section-heading">
      <p class="eyebrow">Episodes</p>
      <h2 id="episodes-heading">Latest briefings</h2>
    </div>

    {loadError && (
      <p class="status" role="alert">{loadError}</p>
    )}

    {!loadError && episodes.length === 0 && (
      <p class="status">
        No briefings have been published yet.
      </p>
    )}

    <div class="episode-list">
      {episodes.map((episode) => (
          <article class="episode">
            <div class="episode-heading">
              <div>
                <h3>{episodeTitle(episode.dateKey)}</h3>

                <p>AI-powered cyber briefing</p>
              </div>

              <a
                class="download"
                href={publicObjectUrl(episode.audioKey)}
                download
              >
                Download
              </a>
            </div>

            <audio
              controls
              preload="metadata"
              src={publicObjectUrl(episode.audioKey)}
            >
              Your browser does not support HTML audio.
            </audio>

            {episode.notesHtml ? (
              <details class="show-notes">
                <summary>Show notes</summary>

                <div
                  class="notes-content"
                  set:html={episode.notesHtml}
                />
              </details>
            ) : (
              <p class="notes-unavailable">
                Show notes are not available for this episode.
              </p>
            )}
          </article>
      ))}
    </div>

    {totalPages > 1 && (
      <nav
        class="pagination"
        aria-label="Podcast pagination"
      >
        {currentPage > 1 && (
          <a href={`/podcast?page=${currentPage - 1}`}>
            ← Newer
          </a>
        )}

        <span>
          Page {currentPage} of {totalPages}
        </span>

        {currentPage < totalPages && (
          <a href={`/podcast?page=${currentPage + 1}`}>
            Older →
          </a>
        )}
      </nav>
    )}
  </section>
</BaseLayout>

<style>
  .podcast-intro {
    padding-bottom: 4rem;
  }

  .episodes {
    padding-bottom: 7rem;
  }

  .section-heading {
    margin-bottom: 1rem;
  }

  .section-heading h2 {
    margin-bottom: 0;
  }

  .status {
    padding: 2rem 0;
  }

  .episode-list {
    display: grid;
  }

  .episode {
    padding: 3.25rem 0;
    border-top: 1px solid var(--line);
  }

  .episode:last-child {
    border-bottom: 1px solid var(--line);
  }

  .episode-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1.4rem;
  }

  .episode-heading h3 {
    font-size: clamp(1.7rem, 4vw, 2.6rem);
    margin: 0;
  }

  .episode-heading p {
    margin: 0.4rem 0 0;
  }

  .download {
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.15rem;
    white-space: nowrap;
  }

  .download:hover {
    color: var(--text);
    border-color: var(--text);
  }

  audio {
    width: 100%;
    height: 42px;
  }

  .show-notes {
    margin-top: 1.5rem;
  }

  .show-notes summary {
    width: max-content;
    color: var(--text);
    cursor: pointer;
    font-weight: 650;
  }

  .notes-content {
    max-width: 860px;
    padding: 1.2rem 0 0.5rem;
  }

  .notes-content :global(h2) {
    font-size: 1.5rem;
    margin: 2.4rem 0 0.8rem;
  }

  .notes-content :global(h3),
  .notes-content :global(h4) {
    font-size: 1.15rem;
    margin: 2rem 0 0.6rem;
  }

  .notes-content :global(p),
  .notes-content :global(li) {
    color: var(--muted);
  }

  .notes-content :global(ul) {
    padding-left: 1.2rem;
  }

  .notes-content :global(li) {
    margin: 0.55rem 0;
  }

  .notes-content :global(a) {
    color: var(--text);
    text-underline-offset: 0.2rem;
  }

  .notes-unavailable {
    margin: 1.3rem 0 0;
    font-size: 0.9rem;
  }

  .pagination {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding-top: 2.5rem;
    color: var(--muted);
  }

  .pagination a {
    text-decoration: none;
    color: var(--text);
  }

  .pagination a:last-child {
    justify-self: end;
  }

  @media (max-width: 640px) {
    .episode-heading {
      flex-direction: column;
      gap: 0.7rem;
    }

    .pagination {
      grid-template-columns: 1fr 1fr;
    }

    .pagination span {
      grid-column: 1 / -1;
      grid-row: 1;
    }
  }
</style>
