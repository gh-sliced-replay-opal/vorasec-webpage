---
import BaseLayout from '../layouts/BaseLayout.astro';
const podcastUrl='https://briefings.vorasec.com/'; // Replace with your real public podcast or latest-briefing URL.
---
<BaseLayout title="AI-Powered Podcast | David"><section class="hero shell"><p class="eyebrow">AI-powered podcast</p><h1>A security briefing designed for listening.</h1><p>CyberNews collects current cybersecurity reporting, prioritizes actively exploited and high-impact threats, and turns the result into a concise audio briefing.</p><div class="buttons"><a class="button primary" href={podcastUrl} target="_blank" rel="noopener noreferrer">Listen to the latest briefing</a></div></section><section class="section shell grid"><article><p class="eyebrow">Collect</p><h3>Trusted reporting</h3><p>Security publications, government advisories, and vulnerability intelligence.</p></article><article><p class="eyebrow">Prioritize</p><h3>Threat-first ordering</h3><p>Known exploitation and watched technologies rise above general news.</p></article><article><p class="eyebrow">Deliver</p><h3>Audio on your schedule</h3><p>A concise briefing for a commute, workout, or morning review.</p></article></section><section class="section shell responsible"><p class="eyebrow">Responsible use of AI</p><h2>AI assists. Sources still matter.</h2><p>AI assists with summarization and narration. Important claims should still be verified against original reporting and authoritative advisories.</p></section></BaseLayout>
<style>.responsible{max-width:760px;margin-left:max(1.25rem,calc((100vw - var(--max))/2))}</style>
