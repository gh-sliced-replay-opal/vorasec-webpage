---
import BaseLayout from '../../layouts/BaseLayout.astro';
const posts=[{href:'/blog/security-automation-should-fail-loudly',title:'Security automation should fail loudly',date:'July 2026',description:'Why visible failure and explicit diagnostics matter in defensive workflows.'}];
---
<BaseLayout title="Blog | David"><section class="hero shell"><p class="eyebrow">Blog</p><h1>Notes on security, systems, and applied AI.</h1><p>Practical lessons from building, breaking, diagnosing, and improving technology.</p></section><section class="section shell posts">{posts.map(post=><article><p class="eyebrow">{post.date}</p><h2><a href={post.href}>{post.title}</a></h2><p>{post.description}</p><a class="button" href={post.href}>Read article</a></article>)}</section></BaseLayout>
<style>.posts{max-width:820px}.posts article{padding:2.5rem 0;border-top:1px solid var(--line)}.posts h2 a{text-decoration:none}</style>
