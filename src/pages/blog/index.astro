---
import BaseLayout from '../../layouts/BaseLayout.astro';
const posts=[{href:'/blog/security-automation-should-fail-loudly',title:'Security automation should fail loudly',date:'July 2026',description:'Why visible failure and explicit diagnostics matter in defensive workflows.'}];
---
<BaseLayout title="Blog | David"><section class="hero shell"><p class="eyebrow">Blog</p><h1>Notes on security, systems, and applied AI.</h1><p>Practical lessons from building, breaking, diagnosing, and improving technology.</p></section><section class="section shell">{posts.map(post=><article class="card"><p class="eyebrow">{post.date}</p><h2><a href={post.href}>{post.title}</a></h2><p>{post.description}</p><a class="button" href={post.href}>Read article</a></article>)}</section></BaseLayout>
