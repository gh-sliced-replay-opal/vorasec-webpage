---
import ContactSection from '../components/ContactSection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;

const overviewRows = [
  ['Level 1', 'Personal Cybersecurity Essentials', 'Personal protection', 'Foundation', 'One-time'],
  ['Level 2', 'Account, Identity & Privacy Protection', 'Personal protection', 'Includes Level 1', 'One-time'],
  ['Level 3', 'Home & Identity Exposure Review', 'Personal protection', 'Includes Levels 1–2', 'One-time'],
  ['Care', 'Personal Protection Care', 'Personal protection', 'Requires Level 2 or 3', 'Subscription'],
  ['Level 4', 'Secure Home Network Deployment', 'Home network', 'Foundation', 'One-time'],
  ['Level 5', 'Ongoing Home Security Care', 'Home network', 'Requires Level 4', 'Quarterly or weekly'],
];
---

<BaseLayout
  title="Personal & Home Cybersecurity Services | VoraSec"
  description="Practical cybersecurity services for individuals and families—from account and identity protection to secure home-network deployment and ongoing care."
>
  <section class="hero shell services-hero">
    <p class="eyebrow">Personal & home cybersecurity services</p>
    <h1>Practical protection for your digital life and your home.</h1>
    <p>
      We help individuals and families secure the accounts, personal information,
      devices, and connected technology they rely on every day. Choose a one-time
      service to establish stronger protection or ongoing care to help maintain it.
    </p>
    <div class="buttons">
      <a class="button primary" href="#service-guide">Find the right service</a>
      <a class="button" href="#contact">Contact VoraSec</a>
    </div>
  </section>

  <section class="section shell" aria-labelledby="paths-heading">
    <p class="eyebrow">Two paths</p>
    <h2 id="paths-heading">Choose the part of your digital life you want to protect.</h2>
    <div class="path-summary">
      <article>
        <p class="path-label">Personal Protection</p>
        <h3>Accounts, identity, privacy, and scam support.</h3>
        <p>
          Levels 1–3 build on one another. Level 2 includes Level 1, and Level 3
          includes Levels 1 and 2. Personal Protection Care is available after
          Level 2 or 3 establishes a secure baseline.
        </p>
        <a class="button" href="/services/personal-protection">View full Personal Protection details</a>
      </article>
      <article>
        <p class="path-label">Home Network Protection</p>
        <h3>A professionally secured foundation for connected homes.</h3>
        <p>
          Level 4 establishes a professionally configured home network. Level 5
          provides optional ongoing care and is available after Level 4.
        </p>
        <a class="button" href="/services/home-network-protection">View full Home Network details</a>
      </article>
    </div>
  </section>

  <section class="section shell" id="service-guide" aria-labelledby="guide-heading">
    <p class="eyebrow">Service guide</p>
    <h2 id="guide-heading">How each offering fits.</h2>
    <div class="service-table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Level</th>
            <th scope="col">Offering</th>
            <th scope="col">Path</th>
            <th scope="col">Relationship</th>
            <th scope="col">Format</th>
          </tr>
        </thead>
        <tbody>
          {overviewRows.map(([level, offering, path, relationship, format]) => (
            <tr>
              <td data-label="Level">{level}</td>
              <th scope="row" data-label="Offering">{offering}</th>
              <td data-label="Path">{path}</td>
              <td data-label="Relationship">{relationship}</td>
              <td data-label="Format">{format}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="table-note">
      Personal Protection Care and Ongoing Home Security Care are separate
      subscriptions. Clients may choose either or both after completing the
      corresponding prerequisite service.
    </p>
  </section>

  <ContactSection returnPath="/services" />
</BaseLayout>

<style>
  .services-hero {
    position: relative;
    max-width: 1000px;
  }

  .services-hero::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: 3rem;
    width: min(28vw, 250px);
    aspect-ratio: 1;
    background: url('/favicon.png') center / contain no-repeat;
    opacity: 0.08;
    pointer-events: none;
  }

  .services-hero > * {
    position: relative;
    z-index: 1;
  }

  .path-summary {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .path-summary article {
    padding: 2rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.018);
  }

  .path-summary h3 {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .path-label {
    color: var(--b);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .service-table-wrap {
    margin-top: 2.5rem;
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  th,
  td {
    padding: 1rem 0.9rem;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    vertical-align: top;
  }

  thead th,
  tbody th {
    color: var(--text);
  }

  thead th {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .table-note {
    max-width: 760px;
    margin-top: 1.4rem;
    font-size: 0.9rem;
  }

  @media (max-width: 760px) {
    .services-hero::after {
      width: 8rem;
      bottom: 1rem;
    }

    .path-summary {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .path-summary article {
      padding: 1.5rem;
    }

    thead {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip-path: inset(50%);
    }

    table,
    tbody,
    tr,
    th,
    td {
      display: block;
      width: 100%;
    }

    tbody tr {
      padding: 1rem 0;
      border-bottom: 1px solid var(--line);
    }

    tbody th,
    tbody td {
      display: grid;
      grid-template-columns: 7.5rem 1fr;
      gap: 0.75rem;
      padding: 0.35rem 0;
      border: 0;
    }

    tbody th::before,
    tbody td::before {
      content: attr(data-label);
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
  }
</style>
