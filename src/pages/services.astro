---
import ContactSection from '../components/ContactSection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;

const overviewRows = [
  {
    service: 'Essentials',
    descriptor: 'A private education and guided-setup session built around your accounts, devices, and concerns.',
    path: 'Personal protection',
    relationship: 'Most families start here',
    format: 'One-time',
    prices: ['$199'],
  },
  {
    service: 'Account Protection',
    descriptor: 'Hands-on protection for the accounts, identity, and privacy that matter most.',
    path: 'Personal protection',
    relationship: 'Account Protection includes Essentials.',
    format: 'One-time',
    prices: ['$995'],
  },
  {
    service: 'Exposure Review',
    descriptor: 'An authorized review of what outsiders can find and reach — before it becomes a problem.',
    path: 'Personal protection',
    relationship: 'Exposure Review includes Essentials and Account Protection.',
    format: 'One-time',
    prices: ['$1,995'],
  },
  {
    service: 'Personal Protection Care',
    descriptor: 'Ongoing help when something online does not feel right.',
    path: 'Personal protection',
    relationship: 'Personal Protection Care is available after Account Protection or Exposure Review.',
    format: 'Monthly',
    prices: ['$89 per month — individual', '$129 per month — home'],
  },
  {
    service: 'Network Deployment',
    descriptor: 'A professionally configured UniFi home network, designed around your household and owned by you.',
    path: 'Home network',
    relationship: 'Home Network foundation',
    format: 'One-time',
    prices: ['From $2,995'],
  },
  {
    service: 'Ongoing Home Security Care',
    descriptor: 'Continued professional attention without managing network security yourself.',
    path: 'Home network',
    relationship: 'Ongoing Home Security Care is available after Network Deployment.',
    format: 'Quarterly or weekly',
    prices: ['$99 per month — quarterly', '$249 per month — weekly'],
  },
];
---

<BaseLayout
  title="Personal & Home Cybersecurity Services | VoraSec"
  description="Practical cybersecurity services for individuals and families—from account and identity protection to secure home-network deployment and ongoing care."
>
  <section class="hero shell services-hero">
    <p class="eyebrow">Personal & home cybersecurity services</p>
    <h1>Practical protection for your digital life and your home.</h1>
    <p>
      We help individuals and families secure the accounts, personal information,
      devices, and connected technology they rely on every day. Choose a one-time
      service to establish stronger protection or ongoing care to help maintain it.
    </p>
    <div class="buttons">
      <a class="button primary" href="#service-guide">Find the right service</a>
      <a class="button" href="#contact">Contact VoraSec</a>
    </div>
  </section>

  <section class="section shell" aria-labelledby="paths-heading">
    <p class="eyebrow">Two paths</p>
    <h2 id="paths-heading">Choose the part of your digital life you want to protect.</h2>
    <div class="path-summary">
      <a
        class="path-card"
        href="/services/personal-protection"
        aria-label="Explore Personal Protection services"
      >
        <article>
          <p class="path-label">Personal Protection</p>
          <h3>Accounts, identity, privacy, and scam support.</h3>
          <p>
            Most families start with Essentials. Account Protection includes
            Essentials, while Exposure Review includes both. Personal Protection
            Care is available after Account Protection or Exposure Review.
          </p>
          <span class="path-cta" aria-hidden="true">View Personal Protection <span>→</span></span>
        </article>
      </a>
      <a
        class="path-card"
        href="/services/home-network-protection"
        aria-label="Explore Home Network Protection services"
      >
        <article>
          <p class="path-label">Home Network Protection</p>
          <h3>A professionally secured foundation for connected homes.</h3>
          <p>
            Network Deployment is the separate Home Network foundation. Ongoing Home
            Security Care provides optional support afterward and is available after
            Network Deployment.
          </p>
          <span class="path-cta" aria-hidden="true">View Home Network Protection <span>→</span></span>
        </article>
      </a>
    </div>
  </section>

  <section class="section shell" id="service-guide" aria-labelledby="guide-heading">
    <p class="eyebrow">Service guide</p>
    <h2 id="guide-heading">How each offering fits.</h2>
    <div class="service-table-wrap">
      <table
        aria-label="VoraSec services, prerequisites, delivery formats, and baseline prices"
        aria-describedby="service-pricing-note"
      >
        <thead>
          <tr>
            <th scope="col">Service</th>
            <th scope="col">Baseline price</th>
            <th scope="col">Path</th>
            <th scope="col">Relationship</th>
            <th scope="col">Format</th>
          </tr>
        </thead>
        <tbody>
          {overviewRows.map(({ service, descriptor, path, relationship, format, prices }) => (
            <tr>
              <th class="service-name" scope="row" data-label="Service">
                <span>{service}</span>
                <small>{descriptor}</small>
              </th>
              <td class="price-cell" data-label="Baseline price">
                <div class="price-values">
                  {prices.map((price) => <span>{price}</span>)}
                </div>
              </td>
              <td data-label="Path">{path}</td>
              <td data-label="Relationship">{relationship}</td>
              <td data-label="Format">{format}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="table-note" id="service-pricing-note">
      Personal Protection Care and Ongoing Home Security Care are separate
      subscriptions. Clients may choose either or both after completing the
      corresponding prerequisite service. Account Protection includes Essentials,
      and Exposure Review includes Essentials and Account Protection. Network
      Deployment is the separate Home Network foundation. One-time prices reflect
      the baseline scope. Any additional scope, hardware, cabling, electrical work,
      travel, or third-party subscriptions beyond the <a href="/removal">one-year removal service</a>
      included with Account Protection will be confirmed before work begins.
    </p>
  </section>

  <ContactSection returnPath="/services" />
</BaseLayout>

<style>
  .services-hero {
    position: relative;
    max-width: 1000px;
  }

  .services-hero::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: 3rem;
    width: min(28vw, 250px);
    aspect-ratio: 1;
    background: url('/favicon.png') center / contain no-repeat;
    opacity: 0.08;
    pointer-events: none;
  }

  .services-hero > * {
    position: relative;
    z-index: 1;
  }

  .path-summary {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .path-card {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .path-card article {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.018);
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      transform 160ms ease;
  }

  .path-card:hover article,
  .path-card:focus-visible article {
    border-color: var(--a);
    background: rgba(255, 255, 255, 0.035);
    transform: translateY(-2px);
  }

  .path-card:focus-visible {
    outline: 2px solid var(--a);
    outline-offset: 4px;
  }

  .path-card h3 {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .path-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    color: var(--text);
    font-weight: 700;
  }

  .path-cta span {
    color: var(--a);
    font-size: 1.25rem;
    transition: transform 160ms ease;
  }

  .path-card:hover .path-cta span,
  .path-card:focus-visible .path-cta span {
    transform: translateX(0.25rem);
  }

  .path-label {
    color: var(--b);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .service-table-wrap {
    margin-top: 2.5rem;
    overflow-x: auto;
  }

  table {
    width: 100%;
    min-width: 960px;
    border-collapse: collapse;
    text-align: left;
  }

  th,
  td {
    padding: 1rem 0.9rem;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    vertical-align: top;
  }

  thead th,
  tbody th {
    color: var(--text);
  }

  .service-name span,
  .service-name small {
    display: block;
  }

  .service-name small {
    margin-top: 0.35rem;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 400;
    line-height: 1.45;
  }

  thead th {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .price-cell {
    color: var(--text);
    font-weight: 700;
    white-space: nowrap;
  }

  .price-cell span {
    display: block;
  }

  .price-cell span + span {
    margin-top: 0.35rem;
  }

  .table-note {
    max-width: 760px;
    margin-top: 1.4rem;
    font-size: 0.9rem;
  }

  @media (max-width: 760px) {
    .services-hero::after {
      width: 8rem;
      bottom: 1rem;
    }

    .path-summary {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .path-card article {
      padding: 1.5rem;
    }

    thead {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip-path: inset(50%);
    }

    table,
    tbody,
    tr,
    th,
    td {
      display: block;
      width: 100%;
      min-width: 0;
    }

    tbody tr {
      padding: 1rem 0;
      border-bottom: 1px solid var(--line);
    }

    tbody th,
    tbody td {
      display: grid;
      grid-template-columns: 7.5rem 1fr;
      gap: 0.75rem;
      padding: 0.35rem 0;
      border: 0;
    }

    tbody th::before,
    tbody td::before {
      content: attr(data-label);
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .price-cell {
      white-space: normal;
    }
  }

  @media (max-width: 420px) {
    tbody th,
    tbody td {
      grid-template-columns: 6.25rem 1fr;
    }
  }
</style>
