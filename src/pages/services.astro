---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;

const TEST_SITE_KEY = '1x00000000000000000000AA';
const turnstileSiteKey = Astro.locals.runtime.env.TURNSTILE_SITE_KEY
  || (import.meta.env.DEV ? TEST_SITE_KEY : '');
const contactStatus = Astro.url.searchParams.get('contact');

const focusAreas = [
  {
    title: 'Threat intelligence & adversary analysis',
    text: 'Research and analysis of threat actor behavior, TTPs, and indicators of compromise—translated into clear intelligence reports, defensive recommendations, and detection opportunities.',
  },
  {
    title: 'Detection engineering & threat hunting',
    text: 'Review and development of detection logic, signatures, hunting strategies, and enrichment methods designed to reveal meaningful malicious activity across security telemetry.',
  },
  {
    title: 'Incident readiness & investigation',
    text: 'Practical improvements to triage, investigation, escalation, containment, and the generation and sharing of threat intelligence reports for defenders and stakeholders.',
  },
  {
    title: 'SOC workflows & analyst enablement',
    text: 'Runbooks, training, workflow reviews, and operational guidance informed by experience handling escalations, mentoring analysts, and supporting high-volume MDR operations.',
  },
  {
    title: 'Security automation & applied AI',
    text: 'Bounded automation for enrichment, prioritization, reporting, and repetitive analyst tasks—with visible reasoning, observable failures, and human judgment preserved.',
  },
  {
    title: 'Personal security & digital hygiene',
    text: 'Practical guidance for individuals and households, including operational security reviews, account and device hardening, privacy-conscious digital hygiene, exposure reduction, and plain-language cybersecurity consulting.',
  },
];
---

<BaseLayout
  title="Services | VoraSec"
  description="Developing cybersecurity services grounded in threat intelligence, intrusion analysis, incident response, detection engineering, and security automation."
>
  <section class="hero shell services-hero">
    <p class="eyebrow">VoraSec services · In development</p>
    <h1>Practical security work, built around useful outcomes.</h1>
    <p>
      VoraSec is being developed as the home for independent cybersecurity
      services grounded in hands-on experience across threat intelligence,
      intrusion analysis, managed detection and response, malware analysis,
      detection engineering, and security operations.
    </p>
    <p>
      The service catalog is still taking shape, but the foundation is established:
      understand the adversary, improve the signal available to defenders, and
      leave security teams better equipped to make decisions.
    </p>
  </section>

  <section class="section shell" aria-labelledby="focus-heading">
    <p class="eyebrow">Planned focus</p>
    <h2 id="focus-heading">Where I expect to help.</h2>
    <div class="services-grid">
      {focusAreas.map((area) => (
        <article>
          <h3>{area.title}</h3>
          <p>{area.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section shell contact-section" id="contact">
    <div class="contact-intro">
      <p class="eyebrow">Early conversations</p>
      <h2>Tell me what you’re working through.</h2>
      <p>
        VoraSec’s services are still evolving, but I’m open to thoughtful
        conversations about security problems that align with the work described
        above. Share enough context to start; sensitive details can wait.
      </p>
      <p class="contact-note">
        Prefer email? <a href="mailto:info@vorasec.com">info@vorasec.com</a>
      </p>
    </div>

    <div class="contact-panel">
      {contactStatus === 'success' && (
        <p class="form-status success" role="status">
          Message received. I’ll follow up from info@vorasec.com.
        </p>
      )}
      {contactStatus === 'invalid' && (
        <p class="form-status error" role="alert">
          Please review the form and try again.
        </p>
      )}
      {contactStatus === 'verification' && (
        <p class="form-status error" role="alert">
          The security check could not be verified. Please try again.
        </p>
      )}
      {contactStatus === 'error' && (
        <p class="form-status error" role="alert">
          The message could not be delivered. Please email info@vorasec.com instead.
        </p>
      )}

      {turnstileSiteKey ? (
        <form class="contact-form" method="post" action="/api/contact">
          <div class="field-row">
            <label>
              <span>Name</span>
              <input name="name" type="text" autocomplete="name" maxlength="120" required />
            </label>
            <label>
              <span>Email</span>
              <input name="email" type="email" autocomplete="email" maxlength="254" required />
            </label>
          </div>

          <label>
            <span>Organization <small>Optional</small></span>
            <input name="organization" type="text" autocomplete="organization" maxlength="120" />
          </label>

          <label>
            <span>Area of interest</span>
            <select name="interest" required>
              <option value="">Select one</option>
              <option value="Threat intelligence and adversary analysis">Threat intelligence & adversary analysis</option>
              <option value="Detection engineering and threat hunting">Detection engineering & threat hunting</option>
              <option value="Incident readiness and investigation">Incident readiness & investigation</option>
              <option value="SOC workflows and analyst enablement">SOC workflows & analyst enablement</option>
              <option value="Security automation and applied AI">Security automation & applied AI</option>
              <option value="Personal security and digital hygiene">Personal security & digital hygiene</option>
              <option value="Something else">Something else</option>
            </select>
          </label>

          <label>
            <span>What would you like to discuss?</span>
            <textarea name="message" rows="7" minlength="20" maxlength="5000" required></textarea>
          </label>

          <label class="honeypot" aria-hidden="true">
            <span>Website</span>
            <input name="website" type="text" tabindex="-1" autocomplete="off" />
          </label>

          <div
            class="cf-turnstile"
            data-sitekey={turnstileSiteKey}
            data-action="contact"
            data-theme="dark"
          ></div>

          <button class="button primary submit-button" type="submit">Start a conversation</button>
          <p class="privacy-note">Your message is emailed to VoraSec and is not stored by this website.</p>
        </form>
      ) : (
        <p class="form-status error">
          The contact form is temporarily unavailable. Please email
          <a href="mailto:info@vorasec.com"> info@vorasec.com</a>.
        </p>
      )}
    </div>
  </section>

  {turnstileSiteKey && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}
</BaseLayout>

<style>
  .services-hero {
    position: relative;
    max-width: 1000px;
  }

  .services-hero::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: 3rem;
    width: min(28vw, 250px);
    aspect-ratio: 1;
    background: url('/favicon.png') center / contain no-repeat;
    opacity: 0.08;
    pointer-events: none;
  }

  .services-hero h1,
  .services-hero > p {
    position: relative;
    z-index: 1;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2.5rem;
    margin-top: 3rem;
  }

  .services-grid article {
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .contact-section {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 6rem;
    align-items: start;
  }

  .contact-intro {
    max-width: 480px;
  }

  .contact-note a {
    color: var(--text);
  }

  .contact-panel {
    padding-top: 0.4rem;
  }

  .contact-form,
  .contact-form label {
    display: grid;
    gap: 0.55rem;
  }

  .contact-form {
    gap: 1.3rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
  }

  .contact-form label > span {
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .contact-form small {
    margin-left: 0.35rem;
    color: var(--muted);
    font-weight: 400;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.035);
    color: var(--text);
    font: inherit;
    padding: 0.8rem 0.9rem;
  }

  .contact-form textarea {
    resize: vertical;
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    border-color: var(--a);
    outline: 2px solid rgba(115, 214, 232, 0.16);
    outline-offset: 2px;
  }

  .contact-form option {
    background: var(--bg2);
    color: var(--text);
  }

  .submit-button {
    width: fit-content;
    cursor: pointer;
    font: inherit;
    white-space: nowrap;
  }

  .privacy-note {
    margin: -0.35rem 0 0;
    font-size: 0.82rem;
  }

  .form-status {
    margin: 0 0 1.5rem;
    padding: 0.9rem 1rem;
    border-left: 2px solid var(--a);
    background: rgba(115, 214, 232, 0.07);
  }

  .form-status.error {
    border-left-color: #f5a7a7;
    background: rgba(245, 167, 167, 0.07);
  }

  .form-status a {
    color: var(--text);
  }

  .honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .services-hero::after {
      width: 8rem;
      bottom: 1rem;
    }

    .services-grid,
    .contact-section,
    .field-row {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
