---
import ContactSection from '../../components/ContactSection.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;

const personalLevels = [
  {
    id: 'level-1',
    level: 'Level 1',
    title: 'Personal Cybersecurity Essentials',
    price: '$199',
    tagline: 'Learn the essentials and put them into practice.',
    text: 'A private 60-minute education and guided setup session designed around your actual accounts, devices, and concerns.',
    included: [
      'Recognizing scams, phishing, fraudulent calls, and urgent payment requests',
      'Safer passwords, two-step verification, account recovery, updates, and backups',
      'Security review and setup for one personal device',
      'Guided placement of credit freezes, with you entering and retaining all sensitive information',
      'Customized printed and digital reference materials',
      'Clear next steps tailored to you',
    ],
    addOn: 'A group version is available for families, neighborhoods, community groups, churches, retirement communities, and similar organizations.',
    bestFor: 'Anyone who wants practical guidance and a stronger personal-security foundation.',
  },
  {
    id: 'level-2',
    level: 'Level 2',
    title: 'Account, Identity & Privacy Protection',
    price: '$995',
    tagline: 'Secure the accounts that matter most and reduce unnecessary exposure.',
    text: 'Includes everything in Level 1, followed by hands-on protection of your priority accounts, identity, and privacy.',
    included: [
      'Password-manager setup and organization',
      'Unique passwords and two-step verification for priority accounts',
      'Review of recovery email addresses, phone numbers, trusted devices, and active sessions',
      'Secure organization of recovery codes',
      'Guided review of social-media and personal-information privacy settings',
      'Training to remove yourself from data-broker and people-search sites, with your own removal tracker and priority plan.',
      'A Family Scam Defense Plan with trusted contacts, a family verification phrase, and rules for unusual financial requests',
      'Includes a free 30-day trial of Personal Protection Care (up to 4 Scam Concierge reviews) — no automatic billing.',
    ],
    bestFor: 'Individuals and families who want important accounts secured and public exposure reduced.',
  },
  {
    id: 'level-3',
    level: 'Level 3',
    title: 'Home & Identity Exposure Review',
    price: '$1,995',
    tagline: 'See what hackers can find before it becomes a problem.',
    text: 'Includes everything in Levels 1 and 2, plus an authorized review of your home-internet and identity exposure.',
    included: [
      'Authorized inspection of the home internet connection from outside the network',
      'Identification of exposed cameras, storage devices, router controls, remote-access tools, and administrative pages',
      'Router and Wi-Fi security review',
      'One-time breach-exposure checks for authorized email addresses',
      'Review of additional identity and public-information exposure',
      'A prioritized, plain-language findings report',
      'A follow-up session to review recommendations',
    ],
    bestFor: 'Clients who want a broader view of what outsiders may be able to discover or reach.',
  },
];
---

<BaseLayout
  title="Personal Protection Services | VoraSec"
  description="Stackable personal cybersecurity services for account security, identity and privacy protection, exposure reviews, scam support, and ongoing care."
>
  <section class="hero shell protection-hero">
    <p class="eyebrow">Personal Protection</p>
    <h1>Protect your accounts, identity, and privacy.</h1>
    <p>
      Begin with practical education, add hands-on protection, and continue as far
      as your needs require. Level 2 includes Level 1, and Level 3 includes both
      levels below it.
    </p>
    <div class="buttons">
      <a class="button primary" href="#level-1">Explore the levels</a>
      <a class="button" href="#contact">Talk with VoraSec</a>
    </div>
  </section>

  <section class="section shell service-track" aria-labelledby="personal-heading">
    <div class="track-heading">
      <p class="eyebrow">Levels 1–3</p>
      <h2 id="personal-heading">Protection that builds from a clear foundation.</h2>
      <p>
        Choose the level where you want to finish. Every higher level includes the
        work below it. Prices shown are package totals, so Levels 2 and 3 already
        include the lower levels in their listed price.
      </p>
    </div>

    <div class="service-list">
      {personalLevels.map((service) => (
        <article class="service-block" id={service.id}>
          <div class="service-heading">
            <p class="service-level">{service.level}</p>
            <div>
              <div class="service-title-row">
                <h3>{service.title}</h3>
                <p class="service-price">
                  <span>{service.price}</span>
                  <small>One-time package</small>
                </p>
              </div>
              <p class="tagline">{service.tagline}</p>
            </div>
          </div>
          <div class="service-body">
            <p>{service.text}</p>
            <h4>Included</h4>
            <ul>
              {service.included.map((item) => <li>{item}</li>)}
            </ul>
            {service.addOn && (
              <p class="add-on"><strong>Optional add-on:</strong> {service.addOn}</p>
            )}
            <p class="best-for"><strong>Best for:</strong> {service.bestFor}</p>
          </div>
        </article>
      ))}
    </div>

    <article class="subscription-block" id="personal-protection-care">
      <div>
        <p class="service-level">Ongoing care</p>
        <h3>Personal Protection Care</h3>
        <div class="care-pricing" aria-label="Personal Protection Care pricing">
          <p>
            <span>Individual</span>
            <strong>$89</strong><small> per month</small>
          </p>
          <p>
            <span>Home</span>
            <strong>$129</strong><small> per month</small>
          </p>
        </div>
        <p class="tagline">Ongoing help when something online does not feel right.</p>
      </div>
      <div>
        <p>
          Available after Level 2 or Level 3 has established a secure baseline for
          your accounts, identity, and privacy.
        </p>
        <h4>Included</h4>
        <ul>
          <li>Individual covers one adult; Home covers two adults living at the same address</li>
          <li>Breach monitoring for 3 authorized email addresses on Individual or 6 authorized email addresses on Home</li>
          <li>Up to 4 Scam Concierge reviews per month, with a response within 48 hours</li>
          <li>One comprehensive personal account, identity, and privacy review per 12 months of continuous enrollment</li>
          <li>Guided response for a breached or compromised account for up to 2 hours per incident; additional time is quoted before work continues</li>
        </ul>
      </div>
    </article>
  </section>

  <section class="section shell cross-link">
    <p class="eyebrow">Also available</p>
    <h2>Looking for a professionally secured home network?</h2>
    <a class="button" href="/services/home-network-protection">Explore Home Network Protection</a>
  </section>

  <ContactSection
    returnPath="/services/personal-protection"
    title="Tell us what you want to protect."
    description="Share the accounts, identity concerns, suspicious activity, or exposure you want help with. Sensitive details can wait until we establish a safe way to continue."
  />
</BaseLayout>

<style>
  .protection-hero,
  .track-heading {
    max-width: 880px;
  }

  .service-list {
    margin-top: 3rem;
    border-top: 1px solid var(--line);
  }

  .service-block,
  .subscription-block {
    display: grid;
    grid-template-columns: 0.75fr 1.25fr;
    gap: 5rem;
    padding: 3.5rem 0;
    border-bottom: 1px solid var(--line);
    scroll-margin-top: 6rem;
  }

  .service-heading {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 1.2rem;
    align-content: start;
  }

  .service-heading h3,
  .subscription-block h3 {
    margin-top: 0;
    font-size: clamp(1.7rem, 3.4vw, 2.45rem);
  }

  .service-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .service-price {
    flex: 0 0 auto;
    margin: 0.1rem 0 0;
    padding-left: 0.75rem;
    border-left: 2px solid var(--b);
    color: var(--text);
    text-align: right;
    white-space: nowrap;
  }

  .service-price span {
    display: block;
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1;
  }

  .service-price small {
    display: block;
    margin-top: 0.35rem;
    color: var(--muted);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .service-level {
    margin: 0.15rem 0 0;
    color: var(--b);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .tagline {
    margin-top: 0.7rem;
    color: var(--text);
  }

  .service-body > p:first-child,
  .subscription-block > div:last-child > p:first-child {
    margin-top: 0;
  }

  .service-block h4,
  .subscription-block h4 {
    margin: 1.7rem 0 0.75rem;
    color: var(--text);
    font-size: 0.92rem;
  }

  .service-block ul,
  .subscription-block ul {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--muted);
  }

  .service-block li,
  .subscription-block li {
    margin: 0.55rem 0;
  }

  .add-on,
  .best-for {
    margin-top: 1.6rem;
    padding-left: 1rem;
    border-left: 1px solid var(--line);
  }

  .service-block strong {
    color: var(--text);
  }

  .subscription-block {
    margin-top: 3rem;
    padding-right: 2rem;
    padding-left: 2rem;
    border: 1px solid rgba(115, 214, 232, 0.22);
    background: rgba(115, 214, 232, 0.035);
  }

  .care-pricing {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1.1rem;
  }

  .care-pricing p {
    margin: 0;
    padding: 0.75rem;
    border: 1px solid var(--line);
  }

  .care-pricing span {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .care-pricing strong {
    color: var(--text);
    font-size: 1.25rem;
  }

  .care-pricing small {
    color: var(--muted);
    font-size: 0.72rem;
  }

  .cross-link {
    max-width: 820px;
    margin-left: max(1.25rem, calc((100vw - var(--max)) / 2));
  }

  @media (max-width: 760px) {
    .service-block,
    .subscription-block {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .subscription-block {
      padding: 1.5rem;
    }

    .service-heading {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .service-title-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .service-price {
      text-align: left;
    }
  }
</style>
