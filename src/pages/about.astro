---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  'Cyber Threat Intelligence',
  'Intrusion Analysis',
  'Detection Engineering',
  'Incident Response',
  'Malware Analysis',
  'Threat Hunting',
  'Intelligence Reporting',
  'Analyst Training',
  'Security Automation',
];

---

<BaseLayout
  title="About VoraSec | Practical Cybersecurity for Individuals & Families"
  description="Learn why VoraSec brings experience from incident response, threat intelligence, malware analysis, and managed detection to personal and home cybersecurity."
>
  <section class="hero shell about-hero">
    <p class="eyebrow">About VoraSec</p>
    <h1>Serious cybersecurity, made practical for everyday life.</h1>
    <p>
      We bring lessons from real investigations, incident response, and threat
      intelligence to the accounts, identities, and technology people depend on at home.
    </p>
  </section>

  <section class="section shell story">
    <article>
      <p class="eyebrow">Why VoraSec exists</p>
      <h2>Most people are expected to manage risks they were never taught to see.</h2>
      <p>
        Personal email now unlocks financial accounts. Public information can help a
        criminal impersonate a family member. A home network may connect work
        computers, cameras, televisions, appliances, and children’s devices without
        meaningful separation.
      </p>
      <p>
        Generic advice rarely tells someone what to do with the technology and
        circumstances in front of them. We created VoraSec to close that gap with
        practical education, hands-on protection, and a trusted source of help when
        something does not look right.
      </p>
      <p>
        We do not sell fear or bury people in technical language. We explain what
        matters, make changes with permission, document what was done, and leave every
        client in control of their technology.
      </p>
    </article>
  </section>

  <section class="section shell founder-story">
    <div>
      <p class="eyebrow">Founder</p>
      <h2>David — military veteran and cybersecurity practitioner.</h2>
    </div>
    <article>
      <p>
        David founded VoraSec after building a career across enterprise security
        operations, incident response, managed detection, malware analysis, detection
        engineering, and cyber threat intelligence.
      </p>
      <p>
        He began by investigating activity across endpoint, network, security-monitoring,
        and threat-intelligence sources. That experience taught him how to preserve
        evidence, separate meaningful signals from background noise, communicate clearly
        under pressure, and make sound decisions with incomplete information.
      </p>
      <p>
        At CrowdStrike, David investigated malicious activity across multiple operating
        systems, analyzed malware, guided junior analysts through escalations, and served
        on a senior analyst team supporting a 150-person managed detection and response
        operation. One investigation helped uncover and stop malicious software
        distributed through a trusted source, preventing further exposure across more
        than two million downloads.
      </p>
      <p>
        His subsequent work has focused on sophisticated adversaries: correlating large
        datasets, developing signatures used to track malicious activity, producing
        actionable intelligence, and training analysts to understand adversary behavior.
      </p>
      <p>
        VoraSec applies that same investigative discipline at a human scale—helping
        individuals and families make better security decisions before and after
        something goes wrong.
      </p>
    </article>
  </section>

  <section class="section shell credentials">
    <article>
      <p class="eyebrow">Education</p>
      <h2>Academic foundation.</h2>
      <p><strong>M.S., Cybersecurity and Information Assurance</strong><br />Western Governors University</p>
      <p><strong>B.S., Information Systems Management</strong><br />University of Maryland Global Campus</p>
    </article>
    <article>
      <p class="eyebrow">Certifications</p>
      <h2>Technical credentials.</h2>
      <p>GIAC Certified Incident Handler (GCIH)</p>
      <p>CompTIA PenTest+ · CySA+ · Security+</p>
    </article>
  </section>

  <section class="section shell expertise">
    <p class="eyebrow">Professional areas</p>
    <ul class="tags">{skills.map((skill) => <li>{skill}</li>)}</ul>
  </section>

  <section class="section shell final-cta">
    <p class="eyebrow">Personal & home protection</p>
    <h2>See how VoraSec can help protect your household.</h2>
    <p>
      Explore one-time services for personal and home security or ongoing care for
      continued monitoring and support.
    </p>
    <div class="buttons">
      <a class="button primary" href="/services">Explore services</a>
      <a class="button" href="/services#contact">Contact VoraSec</a>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero,
  .story article {
    max-width: 880px;
  }

  .founder-story {
    display: grid;
    grid-template-columns: 0.75fr 1.25fr;
    gap: 6rem;
    align-items: start;
  }

  .founder-story article {
    max-width: 720px;
  }

  .founder-story article p:first-child {
    margin-top: 0;
  }

  .credentials {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 5rem;
  }

  .credentials article {
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .credentials strong {
    color: var(--text);
  }

  .expertise {
    max-width: 860px;
    margin-left: max(1.25rem, calc((100vw - var(--max)) / 2));
  }

  .final-cta {
    max-width: 860px;
    margin-left: max(1.25rem, calc((100vw - var(--max)) / 2));
  }

  @media (max-width: 760px) {
    .founder-story,
    .credentials {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
