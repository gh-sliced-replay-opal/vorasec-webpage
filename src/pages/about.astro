import BaseLayout from '../layouts/BaseLayout.astro';
const skills=['SOC Operations','Incident Response','Cyber Threat Intelligence','Security Automation','Cloud Architecture','Linux','n8n','Network Security','Applied AI'];
---
<BaseLayout title="About | David">
<section class="hero shell"><p class="eyebrow">About me</p><h1>Operator, builder, and lifelong student.</h1><p>I’m a military veteran and cybersecurity professional with experience in security operations and incident response. I focus on identifying meaningful threats, improving defensive workflows, and making complicated systems easier to operate.</p><p>I learn best by building. My home lab is a running series of projects where I test new ideas against new tech — a local Security Onion deployment, agentic vulnerability research, and n8n automation workflows are a few of the recent ones.<p></section>
<section class="section shell about"><article><h2>My approach</h2><p>I prefer practical security over security theater. Good systems should reduce uncertainty, preserve evidence, fail visibly, and give an operator enough context to make a sound decision.</p><p>Outside of security work, I build home-lab infrastructure and study how automation and AI can improve analyst workflows without hiding source material or failure modes.</p></article><aside><p class="eyebrow">Core areas</p><ul class="tags">{skills.map(skill=><li>{skill}</li>)}</ul></aside></section>
</BaseLayout>
<style>.about{display:grid;grid-template-columns:1.4fr .8fr;gap:6rem}.about article{max-width:680px}@media(max-width:760px){.about{grid-template-columns:1fr;gap:3rem}}</style>
